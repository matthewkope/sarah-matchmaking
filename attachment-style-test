def ask_likert(texts):
    """Agree/disagree 1–5 questions. Takes a list of statement strings;
    returns a list of ints. Used by attachment, big five, dark triad, type."""
    answers = [None] * len(texts)
    i = 0
    while i < len(texts):
        text = texts[i]
        print(f"\n{DIM}{progress_bar(i, len(texts))}{RESET}")
        print(f"{GREEN}?{RESET} {BOLD}Q{i + 1}. {text}{RESET}\n")
        for n, label in enumerate(SCALE, 1):
            print(f"  {AMBER}[{n}]{RESET} {label}")
        nav = "press 1-5 to answer · B back · Q quit" if i else "press 1-5 to answer · Q quit"
        print(f"{DIM}{nav}{RESET}")
        while True:
            ch = getch()
            if ch in "12345":
                answers[i] = int(ch)
                print(f"{GREEN}> {ch}  — {SCALE[int(ch) - 1]}{RESET}")
                i += 1
                break
            if ch.lower() == "b" and i > 0:
                i -= 1
                answers[i] = None
                print(f"{DIM}> back to Q{i + 1}{RESET}")
                break
            if ch.lower() == "q":
                print(f"{DIM}bye.{RESET}")
                sys.exit(0)
    return answers


def ask_choice(questions):
