def build_love_questions():
    """30 forced-choice questions; returns list of (langA, textA, langB, textB).
    Follows the official quiz's exact pairing sequence (LOVE_SEQUENCE), pulling
    the next unused statement for each language as it comes up."""
    counters = {k: 0 for k in LOVE_KEYS}
    questions = []
    for x, y in LOVE_SEQUENCE:
        sx = LOVE_STATEMENTS[x][counters[x]]; counters[x] += 1
        sy = LOVE_STATEMENTS[y][counters[y]]; counters[y] += 1
        questions.append((x, sx, y, sy))
    return questions


LOVE_QUESTIONS = build_love_questions()


def love_compute(answers):
    """answers: list of chosen language keys → dict of counts for all 5."""
    counts = Counter(answers)
    return {k: counts.get(k, 0) for k in LOVE_KEYS}


def love_primary(scores):
    top = max(scores.values()) if scores else 0
    return [k for k in LOVE_KEYS if scores.get(k, 0) == top]


def render_love(scores, title=None):
    total = sum(scores.values()) or 1
    ranked = sorted(LOVE_KEYS, key=lambda k: scores[k], reverse=True)
    primary = love_primary(scores)
    print(f"\n{DIM}── {title or 'computing results'} ──{RESET}\n")
    for k in ranked:
        c = scores[k]
        pct = round(c / total * 100)
        bar = love_bar(c)
        star = " ★" if k in primary else ""
        print(f"{LOVE_COLORS[k]}{LOVE_NAMES[k]:<22}{RESET} {c:>2} pts ({pct:>2}%) "
              f"{LOVE_COLORS[k]}{bar}{RESET}{AMBER}{star}{RESET}")
    pk = primary[0]
    color = LOVE_COLORS[pk]
    if len(primary) > 1:
        joined = " & ".join(LOVE_NAMES[k] for k in primary)
        print(f"\nRESULT: {color}{BOLD}★ {joined} (tie) ★{RESET}\n")
    else:
        print(f"\nRESULT: {color}{BOLD}★ {LOVE_NAMES[pk]} ★{RESET}\n")
    desc, tips = LOVE_INFO[pk]
    print(f"{DIM}{wrap(desc)}{RESET}\n")
    print(f"{CYAN}things that may help:{RESET}")
    for tip in tips:
        print(f"{DIM}{wrap(tip, width=70, first='  - ', rest='    ')}{RESET}")


def love_bar(count, width=12):
    filled = round(count / 12 * width)
    return f"[{'█' * filled}{'░' * (width - filled)}]"


