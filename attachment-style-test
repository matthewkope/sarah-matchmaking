def attach_compute(answers):
    sums = {"anx": [0, 0], "avo": [0, 0]}
    for (_, dim, reverse), v in zip(ATTACH_QUESTIONS, answers):
        if reverse:
            v = 6 - v
        sums[dim][0] += v
        sums[dim][1] += 1
    return sums["anx"][0] / sums["anx"][1], sums["avo"][0] / sums["avo"][1]


def attach_classify(anxiety, avoidance):
    high_anx, high_avo = anxiety >= 3, avoidance >= 3
    if not high_anx and not high_avo:
        return "secure"
    if high_anx and not high_avo:
        return "anxious"
    if not high_anx and high_avo:
        return "avoidant"
    return "fearful"


def quadrant_map(anxiety, avoidance):
    w, h = 38, 10
    grid = [[" "] * w for _ in range(h)]

    def put(r, c, s):
        for k, char in enumerate(s):
            if c + k < w:
                grid[r][c + k] = char

    put(1, 5, "SECURE")
    put(1, 22, "DISMISSIVE")
    put(8, 5, "ANXIOUS")
    put(8, 23, "FEARFUL")
    mx = min(w - 1, int((avoidance - 1) / 4 * (w - 1) + 0.5))
    my = min(h - 1, int((anxiety - 1) / 4 * (h - 1) + 0.5))
    grid[my][mx] = "◉"

    half = w // 2
    horiz = "─" * half
    side = {2: " low  ", 3: " anx  ", 6: " high ", 7: " anx  "}
    lines = ["        low avoidance ─── high avoidance",
             f"      ┌{horiz}┬{horiz}┐"]
    for r in range(h):
        row = "".join(grid[r])
        lines.append(f"{side.get(r, '      ')}│{row[:half]}│{row[half:]}│")
        if r == h // 2 - 1:
            lines.append(f"      ├{horiz}┼{horiz}┤")
    lines.append(f"      └{horiz}┴{horiz}┘")
    return "\n".join(lines)


def render_attachment(anxiety, avoidance, style_key, title=None):
    name, color, desc, tips = STYLES[style_key]
    print(f"\n{DIM}── {title or 'computing results'} ──{RESET}\n")
    print(f"ANXIETY    {anxiety:.1f}/5  {AMBER}{score_bar(anxiety)}{RESET}")
    print(f"AVOIDANCE  {avoidance:.1f}/5  {BLUE}{score_bar(avoidance)}{RESET}\n")
    print(quadrant_map(anxiety, avoidance))
    print(f"\nRESULT: {color}{BOLD}★ {name} ★{RESET}\n")
    print(f"{DIM}{wrap(desc)}{RESET}\n")
    print(f"{CYAN}things that may help:{RESET}")
    for tip in tips:
        print(f"{DIM}{wrap(tip, width=70, first='  - ', rest='    ')}{RESET}")
    print(f"\n{DIM}If relationship distress is significantly affecting your life, consider\n"
