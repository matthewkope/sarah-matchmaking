def mbti_pole_name(letter, axis):
    if axis == "AT":
        return "Assertive" if letter == "A" else "Turbulent"
    return MBTI_POLE_NAMES[letter]


def mbti_compute(answers):
    score = {ax: 0 for ax in MBTI_AXES}
    count = {ax: 0 for ax in MBTI_AXES}
    for (ax, p, _), v in zip(MBTI_QUESTIONS, answers):
        if v is None:
            continue
        score[ax] += p * (v - 3)
        count[ax] += 1
    axes = {}
    for ax, (pos, neg) in MBTI_AXES.items():
        mx = count[ax] * 2
        pct_pos = (score[ax] + mx) / (2 * mx) * 100 if mx else 50
        letter = pos if pct_pos >= 50 else neg
        lean = round(max(pct_pos, 100 - pct_pos))
        axes[ax] = (letter, lean)
    type4 = axes["EI"][0] + axes["SN"][0] + axes["TF"][0] + axes["JP"][0]
    full = type4 + "-" + axes["AT"][0]
    return {"type": type4, "full": full, "axes": axes}


def mbti_group(type4):
    for name, color, pred, desc in MBTI_GROUPS:
        if pred(type4):
            return name, color, desc
    return MBTI_GROUPS[0][0], MBTI_GROUPS[0][1], MBTI_GROUPS[0][3]


