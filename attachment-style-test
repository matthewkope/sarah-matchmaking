def big5_compute(answers):
    total = {f: 0 for f in BIG5_FACTORS}
    count = {f: 0 for f in BIG5_FACTORS}
    for (f, k, _), v in zip(BIG5_QUESTIONS, answers):
        if v is None:
            continue
        total[f] += v if k > 0 else 6 - v
        count[f] += 1
    return {f: round((total[f] - count[f]) / (count[f] * 4) * 100) for f in BIG5_FACTORS}


def pct_bar(pct, width=24):
    filled = round(pct / 100 * width)
    return f"[{'█' * filled}{'░' * (width - filled)}]"


