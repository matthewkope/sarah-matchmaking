def dt_compute(answers):
    total = {t: 0 for t in DT_TRAITS}
    count = {t: 0 for t in DT_TRAITS}
    for (t, k, _), v in zip(DT_QUESTIONS, answers):
        if v is None:
            continue
        total[t] += v if k > 0 else 6 - v
        count[t] += 1
    mean = {t: total[t] / count[t] for t in DT_TRAITS}
    pct = {t: round((mean[t] - 1) / 4 * 100) for t in DT_TRAITS}
    return mean, pct


