def people_list(profiles):
    """Unique profile names in first-seen order (case-insensitive)."""
    people, seen = [], set()
    for p in profiles:
        nm = p.get("name", "?")
        if nm.lower() not in seen:
            seen.add(nm.lower())
            people.append(nm)
    return people


def save_profile(result):
    quiz_title = QUIZ_TITLES.get(result["quiz"], result["quiz"])
    profiles = load_profiles()
    people = people_list(profiles)

    # Choose which profile to save onto: an existing one, or a new one.
    if people:
        print(f"\n{CYAN}save this {quiz_title} result to:{RESET}")
        for i, nm in enumerate(people, 1):
            taken = [QUIZ_TITLES.get(p.get("quiz", "attachment"))
                     for p in profiles if p.get("name", "").lower() == nm.lower()]
            print(f"  {AMBER}[{i}]{RESET} {nm}  {DIM}({', '.join(taken)}){RESET}")
        print(f"  {AMBER}[N]{RESET} new profile")
        print(f"  {AMBER}[C]{RESET} cancel")
        sel = ask_line("> ").strip().lower()
        if sel in ("c", ""):
            print(f"{DIM}cancelled — not saved.{RESET}")
            return
        if sel == "n":
            name = ask_line(f"{DIM}new profile name (blank to cancel):{RESET} ")
        elif sel.isdigit() and 1 <= int(sel) <= len(people):
            name = people[int(sel) - 1]
        else:
            print(f"{DIM}not a valid choice — not saved.{RESET}")
            return
    else:
        print(f"\n{CYAN}save this {quiz_title} result{RESET}")
        name = ask_line(f"{DIM}new profile name (blank to cancel):{RESET} ")

    if not name:
        print(f"{DIM}cancelled — not saved.{RESET}")
        return

    # Replace an existing result of the same quiz for this person.
    existing = next((p for p in profiles if p.get("name", "").lower() == name.lower()
                     and p.get("quiz", "attachment") == result["quiz"]), None)
    verb = "saved"
    if existing:
        profiles.remove(existing)
        verb = "updated"
    entry = {"name": name, "saved_at": datetime.now().strftime("%Y-%m-%dT%H:%M:%S")}
    entry.update(result)
    profiles.append(entry)
    write_profiles(profiles)
    print(f"{GREEN}{verb} {quiz_title} for '{name}' → {profiles_path()}{RESET}")


QUIZ_KEYS = ["attachment", "love", "bigfive", "darktriad", "mbti", "rice"]
QUIZ_TITLES = {"attachment": "Attachment Style", "love": "Love Language",
               "bigfive": "Big Five", "darktriad": "Dark Triad", "mbti": "Personality Type",
               "rice": "Rice Purity"}


def profile_love_scores(p):
    answers = p.get("answers")
    if isinstance(answers, list) and len(answers) == len(LOVE_QUESTIONS) and all(answers):
        return love_compute(answers)
    stored = p.get("scores")
    if isinstance(stored, dict):
        return {k: int(stored.get(k, 0)) for k in LOVE_KEYS}
    return {k: 0 for k in LOVE_KEYS}


def big5_scores_of(p):
    a = p.get("answers")
    if isinstance(a, list) and len(a) == len(BIG5_QUESTIONS) and all(v is not None for v in a):
        return big5_compute(a)
    stored = p.get("pct") or {}
    return {f: int(stored.get(f, 0)) for f in BIG5_FACTORS}


def dt_scores_of(p):
    a = p.get("answers")
    if isinstance(a, list) and len(a) == len(DT_QUESTIONS) and all(v is not None for v in a):
        return dt_compute(a)
    mean = p.get("mean") or {}
    pct = p.get("pct") or {}
    return ({t: float(mean.get(t, 0)) for t in DT_TRAITS},
            {t: int(pct.get(t, 0)) for t in DT_TRAITS})


def mbti_res_of(p):
    a = p.get("answers")
    if isinstance(a, list) and len(a) == len(MBTI_QUESTIONS) and all(v is not None for v in a):
        return mbti_compute(a)
    axes = p.get("axes") or {}
    full = p.get("full") or p.get("type", "----")
    norm = {ax: (axes.get(ax, ["?", 0])[0], axes.get(ax, ["?", 0])[1]) for ax in MBTI_AXES}
    return {"type": p.get("type") or full[:4], "full": full, "axes": norm}


def rice_score_of(p):
    a = p.get("answers")
    if isinstance(a, list) and len(a) == len(RICE_QUESTIONS):
        return rice_compute(a)[0]
    return int(p.get("score", 0))


def entry_summary(p):
    q = p.get("quiz", "attachment")
    if q == "love":
        return "Love", LOVE_NAMES.get(love_primary(profile_love_scores(p))[0], "?")
    if q == "bigfive":
        pct = big5_scores_of(p)
        top = max(pct, key=pct.get)
        return "Big Five", "High " + BIG5_INFO[top][0]
    if q == "darktriad":
        _, pct = dt_scores_of(p)
        top = max(pct, key=pct.get)
        return "Dark Triad", "High " + DT_INFO[top][0]
    if q == "mbti":
        return "Type", p.get("full") or p.get("type", "?")
    if q == "rice":
        return "Rice Purity", f"Purity {rice_score_of(p)}"
    return "Attachment", STYLES.get(p.get("style", "secure"), ("?",))[0]


def answer_rows(quiz, answers):
    """Returns a list of (question, answer-label) pairs for a recorded result."""
    if quiz == "rice":
        return [(t, "Yes" if answers[i] else "No") for i, t in enumerate(RICE_QUESTIONS)]
    if quiz == "love":
        rows = []
        for i, (la, ta, lb, tb) in enumerate(LOVE_QUESTIONS):
            rows.append(("It's more meaningful to me when…", ta if answers[i] == la else tb))
        return rows
    texts = {
        "attachment": [q[0] for q in ATTACH_QUESTIONS],
        "bigfive": [q[2] for q in BIG5_QUESTIONS],
        "darktriad": [q[2] for q in DT_QUESTIONS],
        "mbti": [q[2] for q in MBTI_QUESTIONS],
    }.get(quiz, [])
    return [(t, SCALE[answers[i] - 1] if answers[i] else "—") for i, t in enumerate(texts)]


def show_answers(profile):
    quiz = profile.get("quiz", "attachment")
    answers = profile.get("answers")
    if not isinstance(answers, list):
        print(f"\n{DIM}(no recorded answers for this result){RESET}")
        print(f"\n{DIM}press any key to go back{RESET}")
        getch()
        return
    print(f"\n{CYAN}── answers · {QUIZ_TITLES.get(quiz, quiz)} ──{RESET}\n")
    for i, (q, a) in enumerate(answer_rows(quiz, answers), 1):
        print(f"{DIM}{i:>3}.{RESET} {q}")
        print(f"      {GREEN}{a}{RESET}")
    print(f"\n{DIM}press any key to go back{RESET}")
    getch()


def show_saved(profile):
    q = profile.get("quiz", "attachment")
    title = f"{profile.get('name', '?')} · {QUIZ_TITLES.get(q, q)}  ({profile.get('saved_at', '')[:10]})"
    if q == "love":
        render_love(profile_love_scores(profile), title=title)
    elif q == "bigfive":
        render_bigfive(big5_scores_of(profile), title=title)
    elif q == "darktriad":
        mean, pct = dt_scores_of(profile)
        render_darktriad(mean, pct, title=title)
    elif q == "mbti":
        render_mbti(mbti_res_of(profile), title=title)
    elif q == "rice":
        score = rice_score_of(profile)
        render_rice(score, 100 - score, title=title)
    else:
        answers = profile.get("answers")
        if isinstance(answers, list) and len(answers) == len(ATTACH_QUESTIONS) and all(answers):
            anxiety, avoidance = attach_compute(answers)
            style_key = attach_classify(anxiety, avoidance)
        else:
            anxiety = float(profile.get("anxiety", 0))
            avoidance = float(profile.get("avoidance", 0))
            style_key = profile.get("style") or attach_classify(anxiety, avoidance)
        render_attachment(anxiety, avoidance, style_key, title=title)
    print(f"\n{DIM}press [A] to see answers · any other key to go back{RESET}")
    if getch().lower() == "a":
        show_answers(profile)


def view_profiles():
    """Browse saved results grouped by person. Numbering runs across the
    whole list; entries are shown under each person's name."""
    while True:
        profiles = load_profiles()
        print(f"\n{CYAN}── saved profiles ──{RESET}\n")
        if not profiles:
            print(f"{DIM}(none saved yet — take a quiz and press [S] to save one){RESET}")
            print(f"\n{DIM}press [B] to go back{RESET}")
            while getch().lower() != "b":
                pass
            return
        # group by name, preserving first-seen order; map display number -> index
        order, groups = [], {}
        for idx, p in enumerate(profiles):
            key = p.get("name", "?").lower()
            if key not in groups:
                groups[key] = (p.get("name", "?"), [])
                order.append(key)
            groups[key][1].append((idx, p))
        num_to_idx, n = {}, 0
        for key in order:
            display, items = groups[key]
            print(f"{BOLD}{display}{RESET}")
            for idx, p in items:
                n += 1
                num_to_idx[n] = idx
                kind, label = entry_summary(p)
                print(f"  {AMBER}{n}){RESET} {DIM}{kind:<12}{RESET} {label:<22} "
                      f"{DIM}{p.get('saved_at', '')[:10]}{RESET}")
            taken = {p.get("quiz", "attachment") for _, p in items}
            missing = [QUIZ_TITLES[q] for q in QUIZ_KEYS if q not in taken]
            if missing:
                print(f"     {DIM}not yet taken: {', '.join(missing)}{RESET}")
            print()
        print(f"{DIM}enter a # to view · [D] delete a # · [B] back{RESET}")
        sel = ask_line("> ").lower()
        if sel in ("b", ""):
            return
        if sel == "d":
            d = ask_line(f"{DIM}delete which # (blank to cancel):{RESET} ")
            if d.isdigit() and int(d) in num_to_idx:
                victim = profiles[num_to_idx[int(d)]]
                kind, label = entry_summary(victim)
                print(f"{AMBER}delete {victim.get('name', '?')}'s {kind} result? [y/N]{RESET}")
                if getch().lower() == "y":
                    profiles.pop(num_to_idx[int(d)])
                    write_profiles(profiles)
                    print(f"{DIM}deleted.{RESET}")
            else:
                print(f"{DIM}nothing deleted.{RESET}")
        elif sel.isdigit() and int(sel) in num_to_idx:
            show_saved(profiles[num_to_idx[int(sel)]])


