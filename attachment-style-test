        nav = "press 1 or 2 · B back · Q quit" if i else "press 1 or 2 · Q quit"
        print(f"{DIM}{nav}{RESET}")
        while True:
            ch = getch()
            if ch in "12":
                answers[i] = langA if ch == "1" else langB
                chosen = textA if ch == "1" else textB
                print(f"{GREEN}> {ch}  — {chosen}{RESET}")
